<view class="container">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <view class="stat">
      <text class="stat-label">已戳破</text>
      <text class="stat-value">{{poppedCount}}</text>
    </view>
    <view class="stat">
      <text class="stat-label">剩余</text>
      <text class="stat-value">{{remainingCount}}</text>
    </view>
    <view class="stat">
      <text class="stat-label">最高分</text>
      <text class="stat-value">{{highScore}}</text>
    </view>
    <view class="stat sound-toggle" bindtap="toggleSound">
      <text class="stat-label">音效</text>
      <text class="sound-icon">{{soundOn ? '🔊' : '🔇'}}</text>
    </view>
  </view>

  <!-- 泡泡纸网格 -->
  <scroll-view
    class="bubble-scroll"
    catchtouchmove="onGridTouchMove"
    bindtouchend="onTouchEnd"
    scroll-y
  >
    <view class="bubble-sheet">
      <block wx:for="{{bubbles}}" wx:key="id">
        <view
          class="bubble-cell {{item.popped ? 'popped' : ''}}"
          data-id="{{item.id}}"
          bindtouchstart="onBubbleTap"
        >
          <!-- 未戳破：立体泡泡 -->
          <view class="bubble-wrap" wx:if="{{!item.popped}}">
            <view class="bubble-dome">
              <view class="bubble-highlight"></view>
            </view>
          </view>
          <!-- 已戳破：凹陷 -->
          <view class="bubble-flat" wx:if="{{item.popped}}">
            <view class="flat-circle"></view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 完成弹窗 -->
  <view class="modal-overlay" wx:if="{{showComplete}}">
    <view class="modal">
      <text class="modal-title">🎉 全部戳完！</text>
      <text class="modal-score">共戳破 {{poppedCount}} 个泡泡</text>
      <text class="modal-record" wx:if="{{isNewRecord}}">🏆 新纪录！</text>
      <view class="modal-btn" bindtap="resetGame">
        <text>🔄 再来一局</text>
      </view>
      <view class="modal-btn modal-btn-back" bindtap="goBack">
        <text>← 返回首页</text>
      </view>
    </view>
  </view>
</view>
