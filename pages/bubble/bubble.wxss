.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
}

.bubble-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  padding: 10rpx 0;
  flex: 1;
  align-content: flex-start;
  overflow-y: auto;
}

.bubble {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  position: relative;
  cursor: pointer;
  transition: transform 0.12s ease, opacity 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}

.bubble-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
}

/* 泡泡颜色 */
.bubble.red .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #ff8a9e, #e94560);
  box-shadow: 0 4rpx 12rpx rgba(233,69,96,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.pink .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #f7c0d1, #d4537e);
  box-shadow: 0 4rpx 12rpx rgba(212,83,126,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.purple .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #cecbf6, #7f77dd);
  box-shadow: 0 4rpx 12rpx rgba(127,119,221,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.blue .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #b5d4f4, #378add);
  box-shadow: 0 4rpx 12rpx rgba(55,138,221,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.teal .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #9fe1cb, #1d9e75);
  box-shadow: 0 4rpx 12rpx rgba(29,158,117,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.green .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #c0dd97, #639922);
  box-shadow: 0 4rpx 12rpx rgba(99,153,34,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.amber .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #fac775, #ba7517);
  box-shadow: 0 4rpx 12rpx rgba(186,117,23,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

/* 爆破瞬间动画 */
.bubble.popping .bubble-inner {
  transform: scale(1.35);
  opacity: 0.7;
  transition: transform 0.08s ease-out, opacity 0.08s ease-out;
}

/* 已戳破 */
.bubble.popped {
  transform: scale(0.2) !important;
  opacity: 0 !important;
  pointer-events: none;
  transition: transform 0.2s ease-out, opacity 0.2s ease-out;
}

/* 爆破闪光 */
.pop-effect {
  position: absolute;
  width: 160%;
  height: 160%;
  left: -30%;
  top: -30%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.8), rgba(255,255,255,0) 70%);
  animation: popFlash 0.25s ease-out forwards;
  pointer-events: none;
  z-index: 10;
}

@keyframes popFlash {
  0% { transform: scale(0.3); opacity: 1; }
  100% { transform: scale(1.8); opacity: 0; }
}

/* ===== 粒子效果 ===== */
.particle {
  position: absolute;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  margin-top: -8rpx;
  margin-left: -8rpx;
  z-index: 20;
  pointer-events: none;
  animation: particleBurst 0.35s ease-out forwards;
}

/* 粒子颜色 */
.particle-red { background: #ff8a9e; box-shadow: 0 0 6rpx rgba(233,69,96,0.6); }
.particle-pink { background: #f7c0d1; box-shadow: 0 0 6rpx rgba(212,83,126,0.6); }
.particle-purple { background: #cecbf6; box-shadow: 0 0 6rpx rgba(127,119,221,0.6); }
.particle-blue { background: #b5d4f4; box-shadow: 0 0 6rpx rgba(55,138,221,0.6); }
.particle-teal { background: #9fe1cb; box-shadow: 0 0 6rpx rgba(29,158,117,0.6); }
.particle-green { background: #c0dd97; box-shadow: 0 0 6rpx rgba(99,153,34,0.6); }
.particle-amber { background: #fac775; box-shadow: 0 0 6rpx rgba(186,117,23,0.6); }

@keyframes particleBurst {
  0% {
    transform: translate(0, 0) scale(1);
    opacity: 1;
  }
  100% {
    transform: translate(calc(var(--tx) * 1rpx), calc(var(--ty) * 1rpx)) scale(0.3);
    opacity: 0;
  }
}

/* 完成弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal {
  background: var(--bg-card);
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  width: 560rpx;
  text-align: center;
}

.modal-title {
  font-size: 44rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.modal-score {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 16rpx;
}

.modal-record {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary);
  display: block;
  margin-bottom: 40rpx;
  animation: pulse 0.8s ease infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.modal-btn {
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn-back {
  background: transparent;
  border: 1rpx solid rgba(255,255,255,0.2);
}
