.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
}

.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
}

.bubble-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  padding: 10rpx 0;
  flex: 1;
  align-content: flex-start;
}

.bubble {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  position: relative;
  cursor: pointer;
  transition: all 0.15s ease;
}

.bubble-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
}

/* 泡泡颜色 */
.bubble.red .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #ff8a9e, #e94560);
  box-shadow: 0 4rpx 12rpx rgba(233,69,96,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.pink .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #f7c0d1, #d4537e);
  box-shadow: 0 4rpx 12rpx rgba(212,83,126,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.purple .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #cecbf6, #7f77dd);
  box-shadow: 0 4rpx 12rpx rgba(127,119,221,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.blue .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #b5d4f4, #378add);
  box-shadow: 0 4rpx 12rpx rgba(55,138,221,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.teal .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #9fe1cb, #1d9e75);
  box-shadow: 0 4rpx 12rpx rgba(29,158,117,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.green .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #c0dd97, #639922);
  box-shadow: 0 4rpx 12rpx rgba(99,153,34,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

.bubble.amber .bubble-inner {
  background: radial-gradient(circle at 35% 35%, #fac775, #ba7517);
  box-shadow: 0 4rpx 12rpx rgba(186,117,23,0.4), inset 0 -4rpx 8rpx rgba(0,0,0,0.2), inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

/* 弹出动画 */
.bubble.popping {
  transform: scale(1.3);
  opacity: 0.5;
}

.bubble.popping .bubble-inner {
  box-shadow: 0 0 20rpx rgba(255,255,255,0.5);
}

/* 已弹出 */
.bubble.popped {
  transform: scale(0.3);
  opacity: 0;
  pointer-events: none;
}

/* 弹出特效 */
.pop-effect {
  position: absolute;
  width: 140%;
  height: 140%;
  left: -20%;
  top: -20%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.6), transparent 70%);
  animation: popFlash 0.3s ease-out forwards;
  pointer-events: none;
}

@keyframes popFlash {
  0% { transform: scale(0.5); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* 完成弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal {
  background: var(--bg-card);
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  width: 560rpx;
  text-align: center;
}

.modal-title {
  font-size: 44rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.modal-score {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 16rpx;
}

.modal-record {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary);
  display: block;
  margin-bottom: 40rpx;
  animation: pulse 0.8s ease infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.modal-btn {
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn-back {
  background: transparent;
  border: 1rpx solid rgba(255,255,255,0.2);
}
