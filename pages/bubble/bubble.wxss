/* 塑料泡泡纸风格 */
.container {
  min-height: 100vh;
  background: #1a1a2e;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
}

.sound-toggle {
  cursor: pointer;
}

.sound-icon {
  font-size: 36rpx;
}

/* 可滚动区域 */
.bubble-scroll {
  flex: 1;
  overflow: hidden;
}

/* 泡泡纸底板 - 塑料质感 */
.bubble-sheet {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f0d8 0%, #ece5c0 50%, #e8dfb5 100%);
  border-radius: 16rpx;
  box-shadow:
    0 4rpx 20rpx rgba(0,0,0,0.3),
    inset 0 2rpx 4rpx rgba(255,255,255,0.3);
  /* 塑料纹理 */
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 96rpx,
      rgba(0,0,0,0.03) 96rpx,
      rgba(0,0,0,0.03) 98rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 96rpx,
      rgba(0,0,0,0.03) 96rpx,
      rgba(0,0,0,0.03) 98rpx
    );
}

/* 每个泡泡的格子 */
.bubble-cell {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  -webkit-tap-highlight-color: transparent;
}

/* 泡泡立体凸起 */
.bubble-wrap {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  animation: bubbleFloat 3s ease-in-out infinite;
}

/* 泡泡圆顶 - 塑料质感 */
.bubble-dome {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: radial-gradient(
    ellipse at 35% 30%,
    rgba(255,255,255,0.9) 0%,
    rgba(220,215,180,0.7) 25%,
    rgba(200,195,160,0.5) 50%,
    rgba(180,175,140,0.3) 75%,
    rgba(160,155,120,0.1) 100%
  );
  box-shadow:
    0 4rpx 8rpx rgba(0,0,0,0.15),
    inset 0 -6rpx 12rpx rgba(0,0,0,0.08),
    inset 0 4rpx 8rpx rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.4);
  position: relative;
  transition: transform 0.08s ease;
}

/* 高光点 */
.bubble-highlight {
  position: absolute;
  width: 20rpx;
  height: 16rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  top: 14rpx;
  left: 18rpx;
  filter: blur(2rpx);
}

/* 戳破瞬间 */
.bubble-wrap.popping {
  animation: popBubble 0.2s ease-out forwards;
}

@keyframes popBubble {
  0% { transform: scale(1); }
  30% { transform: scale(1.3); }
  60% { transform: scale(0.8); opacity: 0.5; }
  100% { transform: scale(0); opacity: 0; }
}

/* 已戳破 - 凹陷效果 */
.bubble-flat {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flat-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: radial-gradient(
    ellipse at 50% 50%,
    rgba(0,0,0,0.08) 0%,
    rgba(180,175,140,0.4) 60%,
    rgba(200,195,160,0.6) 100%
  );
  box-shadow:
    inset 0 4rpx 8rpx rgba(0,0,0,0.12),
    inset 0 -2rpx 4rpx rgba(255,255,255,0.2);
  border: 1rpx solid rgba(0,0,0,0.06);
}

/* 浮动动画 - 每个泡泡略有不同 */
@keyframes bubbleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3rpx); }
}

/* 戳破时震动效果 */
.shake {
  animation: shakeAnim 0.1s ease;
}

@keyframes shakeAnim {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4rpx); }
  75% { transform: translateX(4rpx); }
}

/* 完成弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal {
  background: #2a2a4a;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  width: 540rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
}

.modal-title {
  font-size: 44rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.modal-score {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 16rpx;
}

.modal-record {
  font-size: 32rpx;
  font-weight: 500;
  color: #ff6b6b;
  display: block;
  margin-bottom: 40rpx;
  animation: pulse 0.8s ease infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.modal-btn {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(238,90,36,0.4);
}

.modal-btn:active { opacity: 0.8; }

.modal-btn-back {
  background: transparent;
  border: 1rpx solid rgba(255,255,255,0.2);
  box-shadow: none;
}
