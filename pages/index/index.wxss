.container {
  min-height: 100vh;
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

.game-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.game-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 36rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

.game-card.coming-soon {
  opacity: 0.5;
}

.game-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bubble-icon {
  background: rgba(233, 69, 96, 0.15);
}

.mini-bubble {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: var(--primary);
  position: absolute;
}

.bubble-icon { position: relative; }
.b1 { top: 20rpx; left: 20rpx; opacity: 0.6; }
.b2 { top: 30rpx; left: 44rpx; opacity: 0.8; }
.b3 { top: 48rpx; left: 32rpx; opacity: 1; }

.btn-icon {
  background: rgba(22, 199, 154, 0.15);
}

.mini-btn {
  width: 40rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: var(--accent);
}

.sand-icon {
  background: rgba(239, 159, 39, 0.15);
}

.sand-pile {
  width: 50rpx;
  height: 36rpx;
  border-radius: 0 0 50% 50%;
  background: #EF9F27;
}

.game-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  flex: 1;
}

.game-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  flex: 1;
  display: block;
  margin-top: 6rpx;
}

.game-tag {
  font-size: 20rpx;
  background: var(--primary);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.tag-soon {
  background: rgba(255,255,255,0.15);
}

.footer {
  margin-top: auto;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
}
